    public static int first(int[] arr,int low,int high,int x){
        int first=-1;
        while(low<=high){
            int mid=low+(high-low)/2;
            if(arr[mid]==x){
                first=mid;
                high=mid-1;
            }
            else if(arr[mid]<x)low=mid+1;
            else high=mid-1;
        }
        return first;
    }

    public static int last(int[] arr,int low,int high,int x){
        int last=-1;
        while(low<=high){
            int mid=low+(high-low)/2;
            if(arr[mid]==x){
                last=mid;
                low=mid+1;
            }
            else if(arr[mid]>x)high=mid-1;
            else low=mid+1;
        }
        return last;
    }






