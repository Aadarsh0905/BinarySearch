    //iterative
    public static int BS(int[] arr, int low,int high,int target){
        while(low<=high){
            int mid=low+(high-low)/2;
            if(arr[mid]==target)return mid;
            else if(arr[mid]>target)high=mid-1;
            else low=mid+1;
        }
        return -1;
    }

}

